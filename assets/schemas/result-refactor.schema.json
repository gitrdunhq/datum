{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM REFACTOR Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "agent_role", "task_id", "status", "acceptance_criteria"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "agent_role": { "const": "REFACTOR" },
    "task_id": { "type": "string", "pattern": "^task-\\d+$" },
    "status": {
      "type": "string",
      "enum": ["done", "done_with_risks", "failed", "missing_ac", "hard_stop"]
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "satisfied"],
        "properties": {
          "id": { "type": "string" },
          "satisfied": { "type": "boolean" },
          "evidence": { "type": "string" },
          "reason": { "type": "string" },
          "skeleton_function": { "type": "string" }
        }
      }
    },
    "commits": { "type": "array" },
    "verified_green": { "type": "boolean" },
    "ac_checklist": { "type": "array" },
    "missing_acs": { "type": "array" },
    "lane_tools_added": { "type": "array" },
    "brief_defects": { "type": "array" },
    "risks": { "type": "array" },
    "proof_of_work_path": { "type": ["string", "null"] },
    "reason": { "type": "string" },
    "retryable": { "type": "boolean" }
  }
}
