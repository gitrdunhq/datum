{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quality Profile",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": { "type": "string" },
    "required_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "preferred_commands"],
        "properties": {
          "id": { "type": "string" },
          "preferred_commands": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "required": { "type": "boolean", "default": true }
        }
      }
    },
    "review_dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "weight", "required", "pass"],
        "properties": {
          "id": { "type": "string" },
          "weight": { "type": "integer", "minimum": 0 },
          "required": { "type": "boolean" },
          "pass": { "type": "string", "description": "Observable pass condition" }
        }
      }
    },
    "evidence_requirements": {
      "type": "object",
      "properties": {
        "file_line_references": { "type": "boolean", "default": true },
        "command_outputs": { "type": "boolean", "default": true }
      }
    },
    "pass_policy": {
      "type": "object",
      "properties": {
        "required_dimensions_must_pass": { "type": "boolean", "default": true },
        "min_score": { "type": "integer", "minimum": 0, "maximum": 100, "default": 75 },
        "unresolved_high_findings_allowed": { "type": "integer", "minimum": 0, "default": 0 },
        "blocking_severities": {
          "type": "array",
          "items": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "default": ["critical", "high"]
        }
      }
    }
  }
}
