{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lane Plan Entry",
  "type": "object",
  "required": ["id", "files", "acceptance_criteria", "red_note"],
  "properties": {
    "id": { "type": "string", "pattern": "^task-\\d+$" },
    "title": { "type": "string" },
    "files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "red_note": { "type": "string", "minLength": 1 },
    "introduces_stubs": { "type": "boolean" },
    "estimated_loc": { "type": "integer" },
    "depends_on": { "type": "array", "items": { "type": "string" } },
    "signature_deps": { "type": "array", "items": { "type": "string" } },
    "behavior_deps": { "type": "array", "items": { "type": "string" } },
    "file_conflict_with": { "type": "object" },
    "stage": {
      "type": "string",
      "enum": ["queued", "RED", "GREEN", "REFACTOR", "completed", "failed_terminal"]
    }
  }
}
