{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM RED Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "agent_role",
    "task_id",
    "run_id",
    "spec_excerpt",
    "properties",
    "acceptance_criteria",
    "files_to_write",
    "red_note",
    "introduces_stubs",
    "stub_files",
    "language",
    "framework",
    "gitnexus_context",
    "upstream_stubs",
    "lane_tools_readme"
  ],
  "properties": {
    "contract_version": { "const": "1.0" },
    "agent_role": { "const": "RED" },
    "task_id": { "type": "string", "pattern": "^task-\\d+$" },
    "run_id": { "type": "string", "pattern": "^epic-\\d+-\\d{8}-\\d{6}$" },
    "spec_excerpt": { "type": "string", "minLength": 1 },
    "properties": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "category", "predicate"],
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string" },
          "predicate": { "type": "string", "minLength": 1 }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "files_to_write": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "red_note": { "type": "string", "minLength": 1 },
    "introduces_stubs": { "type": "boolean" },
    "stub_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "language": { "type": "string", "minLength": 1 },
    "framework": { "type": "string", "minLength": 1 },
    "gitnexus_context": { "type": ["string", "null"] },
    "upstream_stubs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "content"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "content": { "type": "string" }
        }
      }
    },
    "lane_tools_readme": { "type": "string" }
  }
}
