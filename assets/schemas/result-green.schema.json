{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM GREEN Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "agent_role", "task_id", "status", "acceptance_criteria", "attempt"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "agent_role": { "const": "GREEN" },
    "task_id": { "type": "string", "pattern": "^task-\\d+$" },
    "status": { "type": "string", "enum": ["done", "failed", "hard_stop"] },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "satisfied"],
        "properties": {
          "id": { "type": "string" },
          "satisfied": { "type": "boolean" },
          "evidence": { "type": "string" },
          "reason": { "type": "string" },
          "skeleton_function": { "type": "string" }
        }
      }
    },
    "commits": { "type": "array" },
    "verified_green": { "type": "boolean" },
    "attempt": { "type": "integer", "minimum": 1 },
    "turn": { "type": "integer", "minimum": 1 },
    "reason": { "type": "string" },
    "retryable": { "type": "boolean" }
  }
}
