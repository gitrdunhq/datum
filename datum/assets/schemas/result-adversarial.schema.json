{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM ADVERSARIAL Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "agent_role", "task_id", "status", "acceptance_criteria"],
  "properties": {
    "contract_version": { "const": "1.0" },
    "agent_role": { "const": "ADVERSARIAL" },
    "task_id": { "type": "string", "pattern": "^task-\\d+$" },
    "status": { "type": "string", "enum": ["done", "failed", "hard_stop"] },
    "acceptance_criteria": { "type": "array", "minItems": 1 },
    "candidates": { "type": "array" },
    "no_gaps_found": { "type": "boolean" },
    "reason": { "type": "string" },
    "retryable": { "type": "boolean" }
  }
}
