{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Candidate Edge Cases",
  "type": "object",
  "required": ["contract_version", "agent_role", "task_id", "candidates"],
  "properties": {
    "contract_version": { "type": "string" },
    "agent_role": { "type": "string", "const": "ADVERSARIAL" },
    "task_id": { "type": "string", "pattern": "^task-\\d+$" },
    "no_gaps_found": { "type": "boolean", "default": false },
    "reasoning": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "property_id", "description", "expected_violation", "verdict"],
        "properties": {
          "id": { "type": "string" },
          "property_id": { "type": "string" },
          "description": { "type": "string" },
          "input_specification": { "type": "string" },
          "expected_violation": { "type": "string" },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "verdict": {
            "type": "string",
            "enum": ["gap", "likely_covered", "out_of_scope"]
          },
          "refactor_verdict": {
            "type": "string",
            "enum": ["real_gap", "covered", "not_applicable"],
            "description": "Filled in by REFACTOR during adversarial review"
          },
          "refactor_evidence": { "type": "string" }
        }
      }
    }
  }
}
