{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artifact Envelope",
  "description": "Standard DATUM artifact envelope for all pipeline payloads",
  "type": "object",
  "properties": {
    "datum_version": {
      "type": "string",
      "default": "1.0"
    },
    "type": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "blocked", "error"]
    },
    "payload": {
      "type": "object"
    }
  },
  "required": ["datum_version", "type", "owner", "status", "payload"],
  "additionalProperties": false
}
