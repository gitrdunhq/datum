{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM REFACTOR Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "agent_role",
    "task_id",
    "run_id",
    "spec_excerpt",
    "properties",
    "acceptance_criteria",
    "files_to_write",
    "language",
    "framework",
    "implementation_files",
    "test_files",
    "test_results",
    "gitnexus_impact",
    "lane_tools_readme",
    "brief_defects_so_far"
  ],
  "properties": {
    "contract_version": { "const": "1.0" },
    "agent_role": { "const": "REFACTOR" },
    "task_id": { "type": "string", "pattern": "^task-\\d+$" },
    "run_id": { "type": "string", "pattern": "^epic-\\d+-\\d{8}-\\d{6}$" },
    "spec_excerpt": { "type": "string", "minLength": 1 },
    "properties": { "type": "array", "minItems": 1 },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "files_to_write": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "language": { "type": "string", "minLength": 1 },
    "framework": { "type": "string", "minLength": 1 },
    "implementation_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "content"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "content": { "type": "string" }
        }
      }
    },
    "test_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "content"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "content": { "type": "string" }
        }
      }
    },
    "test_results": { "type": "string" },
    "gitnexus_impact": { "type": ["string", "null"] },
    "lane_tools_readme": { "type": "string" },
    "brief_defects_so_far": { "type": "array" }
  }
}
