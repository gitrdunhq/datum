{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM GREEN Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "agent_role",
    "task_id",
    "run_id",
    "spec_excerpt",
    "properties",
    "acceptance_criteria",
    "files_to_write",
    "language",
    "framework",
    "test_signal",
    "gitnexus_context",
    "lane_tools_readme",
    "attempt"
  ],
  "properties": {
    "contract_version": { "const": "1.0" },
    "agent_role": { "const": "GREEN" },
    "task_id": { "type": "string", "pattern": "^task-\\d+$" },
    "run_id": { "type": "string", "pattern": "^epic-\\d+-\\d{8}-\\d{6}$" },
    "spec_excerpt": { "type": "string", "minLength": 1 },
    "properties": { "type": "array", "minItems": 1 },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "files_to_write": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "language": { "type": "string", "minLength": 1 },
    "framework": { "type": "string", "minLength": 1 },
    "test_signal": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "assertion_failures", "compile_errors", "runtime_errors"],
      "properties": {
        "status": { "type": "string", "enum": ["fail", "compile_error", "runtime_error"] },
        "assertion_failures": { "type": "array" },
        "compile_errors": { "type": "array" },
        "runtime_errors": { "type": "array" }
      }
    },
    "gitnexus_context": { "type": ["string", "null"] },
    "lane_tools_readme": { "type": "string" },
    "attempt": { "type": "integer", "minimum": 1 }
  }
}
