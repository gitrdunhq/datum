{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "file": {"type": "string"},
          "severity": {"type": "string"},
          "description": {"type": "string"}
        },
        "required": ["id", "file", "severity", "description"]
      }
    }
  },
  "required": ["findings"]
}
