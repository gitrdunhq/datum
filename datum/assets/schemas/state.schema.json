{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM State",
  "type": "object",
  "required": ["schema_version", "run_id", "skill_version", "current_phase", "phases", "lanes", "git"],
  "properties": {
    "schema_version": { "type": "string" },
    "run_id": { "type": "string", "pattern": "^epic-\\d+-\\d{8}-\\d{6}$" },
    "skill_version": { "type": "string" },
    "current_phase": {
      "type": "string",
      "enum": ["discovery","refine","plan","properties","act","validate","review","pr_comments","closeout"]
    },
    "phases": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["pending","in_progress","completed","failed","closeout_pending"] },
          "model": { "type": "string" },
          "artifact": { "type": "string" },
          "started_at": { "type": "string", "format": "date-time" },
          "completed_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "lanes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "stage": { "type": "string", "enum": ["queued","RED","GREEN","REFACTOR","completed","failed_terminal"] },
          "sub_stage": { "type": "string", "enum": ["stub_committed","test_committed","verified_red"] },
          "stages": { "type": "object" },
          "files_touched": { "type": "array", "items": { "type": "string" } },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "blocked_on_dependency": { "type": "array", "items": { "type": "string" } },
          "blocked_on_file_conflict": { "type": ["string","null"] }
        }
      }
    },
    "in_flight_count": { "type": "integer", "minimum": 0 },
    "in_flight_cap": { "type": "integer", "minimum": 1, "maximum": 20 },
    "git": {
      "type": "object",
      "required": ["base_branch", "work_branch"],
      "properties": {
        "base_branch": { "type": "string" },
        "work_branch": { "type": "string" },
        "head_sha": { "type": ["string","null"] },
        "pr_url": { "type": ["string","null"] },
        "merge_sha": { "type": ["string","null"] }
      }
    },
    "brief_defects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["task_id","missing_ac","surfaced_by_stage"],
        "properties": {
          "task_id": { "type": "string" },
          "missing_ac": { "type": "string" },
          "surfaced_by_stage": { "type": "string" }
        }
      }
    },
    "lane_tools_added": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "description": { "type": "string" },
          "added_in_lane": { "type": "string" }
        }
      }
    },
    "gitnexus_degraded": { "type": "boolean" },
    "gitnexus_degraded_log": { "type": ["object","null"] },
    "config_hash": { "type": ["string","null"] },
    "gitnexus_index_sha": { "type": ["string","null"] },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
