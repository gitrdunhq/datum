{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Follow-up Issue",
  "type": "object",
  "required": ["dedup_key","title","body","severity","source"],
  "properties": {
    "dedup_key": { "type": "string", "description": "Stable key for idempotent filing" },
    "title": { "type": "string", "minLength": 1 },
    "body": { "type": "string" },
    "severity": { "type": "string", "enum": ["critical","high","medium","low","info"] },
    "category": {
      "type": "string",
      "enum": [
        "flaky_test","brief_defect","coverage_gap","efficiency_regression",
        "blast_radius_exceeded","say_do_gap","lane_tool_missing_description",
        "token_cost_regression","other"
      ]
    },
    "suggested_labels": { "type": "array", "items": { "type": "string" } },
    "source": { "type": "string", "description": "Which closeout collector or stage generated this" },
    "filed_url": { "type": ["string","null"], "description": "Issue URL after filing, null if not yet filed" },
    "filed_at": { "type": ["string","null"], "format": "date-time" }
  }
}
