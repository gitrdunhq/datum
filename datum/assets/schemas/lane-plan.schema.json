{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DATUM Lane Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "total_lanes", "topological_order", "file_ownership", "lanes"],
  "properties": {
    "schema_version": { "type": "string" },
    "total_lanes": { "type": "integer", "minimum": 1 },
    "topological_order": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "pattern": "^task-\\d+$" }
    },
    "file_ownership": {
      "type": "object",
      "additionalProperties": { "type": "string", "pattern": "^task-\\d+$" }
    },
    "lanes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "title", "files", "acceptance_criteria", "red_note", "stage"],
        "properties": {
          "id": { "type": "string", "pattern": "^task-\\d+$" },
          "title": { "type": "string", "minLength": 1 },
          "files": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "red_note": { "type": "string", "minLength": 1 },
          "stage": { "type": "string" }
        }
      }
    }
  }
}
